PORT=3000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/chatify

# Redis (optional — app works without it using in-memory fallback)
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_at_least_16_chars
JWT_REFRESH_SECRET=your_refresh_secret_at_least_16_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Client
CLIENT_URL=http://localhost:5173

# Email (Resend) — optional, emails logged to console if not set
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Chatify

# Cloudinary — optional, media uploads disabled if not set
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Arcjet — optional, rate limiting disabled if not set
# ARCJET_KEY=your_arcjet_key
# ARCJET_ENV=development

# Google OAuth — optional
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=/api/auth/google/callback

# AI — optional
# GEMINI_API_KEY=your_gemini_api_key